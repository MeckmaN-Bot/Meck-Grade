# Meck-Grade Environment Configuration
# Copy this file to .env and adjust as needed.
# When running locally (python run.py), these are optional.
# When running via Docker, MECKGRADE_HOST must be 0.0.0.0.

# Server host — use 127.0.0.1 for local-only, 0.0.0.0 for Docker/public
MECKGRADE_HOST=127.0.0.1

# Server port (default: 8374 — "MECK" on phone keypad)
MECKGRADE_PORT=8374
